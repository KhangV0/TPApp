@{
    ViewData["Title"] = "Quản lý Tin bài";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-newspaper"></i> Tin bài</h3>
        <div class="card-tools">
            <button class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> Thêm mới</button>
        </div>
    </div>
    <div class="card-body">
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> Chức năng quản lý tin bài đang được phát triển.
        </div>
    </div>
</div>
