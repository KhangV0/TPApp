<style>
/* ═══════════════════════════════════════════════════════════════
   HOME ENTERPRISE ANALYTICS — Static Data Version
   ═══════════════════════════════════════════════════════════════ */
.tp-metrics { padding: 52px 0 !important; }

.tp-metrics__grid {
  display: grid;
  gap: 28px;
  grid-template-columns: 1fr 1.45fr;
  align-items: stretch;
}

/* ─── Shared typography ──────────────────────────────────── */
.tp-overline {
  font-size: .68rem; letter-spacing: .14em; text-transform: uppercase;
  color: #3b82f6; font-weight: 700; display: block; margin-bottom: 6px;
}
.tp-title { margin: 0 0 6px; font-size: 1.65rem; font-weight: 800; color: #0f172a; letter-spacing: -.03em; }
.tp-sub   { margin: 0 0 22px; color: #64748b; font-size: .88rem; line-height: 1.6; }

/* ─── KPI cards 4×2 ──────────────────────────────────────── */
.tp-kpi__cards {
  display: grid; gap: 12px;
  grid-template-columns: 1fr 1fr;
  margin-bottom: 16px;
}
.tp-card {
  position: relative;
  border: 1px solid #e5e7eb;
  border-radius: 16px;
  padding: 14px;
  background: #fff;
  box-shadow: 0 8px 22px rgba(15,23,42,.05);
  transition: transform .2s ease, box-shadow .2s ease;
  min-height: 100px;
  overflow: hidden;
}
.tp-card:hover { transform: translateY(-3px); box-shadow: 0 14px 32px rgba(15,23,42,.09); }
.tp-card__icon {
  width: 36px; height: 36px; border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
}
.tp-card__icon svg { width: 17px; height: 17px; }

.i-blue   { background: rgba(59,130,246,.12);  color: #2563eb; }
.i-cyan   { background: rgba(6,182,212,.12);   color: #0891b2; }
.i-green  { background: rgba(16,185,129,.12);  color: #059669; }
.i-amber  { background: rgba(245,158,11,.12);  color: #d97706; }
.i-purple { background: rgba(139,92,246,.12);  color: #7c3aed; }
.i-rose   { background: rgba(244,63,94,.12);   color: #e11d48; }
.i-indigo { background: rgba(99,102,241,.12);  color: #4f46e5; }
.i-teal   { background: rgba(20,184,166,.12);  color: #0d9488; }

.tp-card__meta  { margin-top: 9px; }
.tp-card__value { font-size: 1.75rem; font-weight: 900; color: #0f172a; letter-spacing: -.04em; font-variant-numeric: tabular-nums; line-height: 1; }
.tp-card__label { color: #475569; font-size: .71rem; margin-top: 3px; font-weight: 500; }

.tp-updated {
  display: inline-flex; align-items: center; gap: 4px;
  font-size: .68rem; color: #94a3b8;
}

/* ─── Analytics light panel ─────────────────────────────── */
.tp-analytics {
  --tp-analytics-bg : linear-gradient(135deg, #f8fbff, #eef4ff);
  --tp-panel-bg     : #ffffff;
  --tp-border       : #dce8f8;
  --tp-shadow       : 0 10px 30px rgba(37,99,235,.08);
  --tp-text         : #0f172a;
  --tp-muted        : #64748b;

  border-radius: 20px;
  padding: 24px;
  background: var(--tp-analytics-bg);
  border: 1.5px solid var(--tp-border);
  box-shadow: var(--tp-shadow);
  color: var(--tp-text);
}

.tp-analytics__head {
  display: flex; gap: 14px; align-items: flex-start; justify-content: space-between;
  margin-bottom: 18px;
}
.tp-analytics .tp-title { color: #0f172a; font-size: 1.4rem; }
.tp-analytics .tp-sub   { color: #64748b; }

/* ─── Chart panels ──────────────────────────────────────── */
.tp-analytics__row {
  display: grid; gap: 14px;
  grid-template-columns: 1.45fr 1fr;
}
.tp-panel {
  border-radius: 14px;
  padding: 16px;
  background: #ffffff;
  border: 1.5px solid #dce8f8;
  box-shadow: 0 4px 14px rgba(37,99,235,.08);
}
.tp-panel__title { font-weight: 800; font-size: .9rem;  color: #0f172a; }
.tp-panel__hint  { font-size: .7rem; color: #94a3b8; margin: 3px 0 10px; }

/* ─── 4 Stat Boxes ──────────────────────────────────────── */
.tp-stat-boxes {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  margin-top: 14px;
}
.tp-stat-box {
  border-radius: 14px;
  padding: 14px 12px;
  background: #fff;
  border: 1.5px solid #dce8f8;
  box-shadow: 0 2px 8px rgba(37,99,235,.06);
  display: flex; flex-direction: column; align-items: center;
  text-align: center; gap: 4px;
  transition: transform .2s ease;
}
.tp-stat-box:hover { transform: translateY(-2px); }
.tp-stat-box__icon {
  width: 34px; height: 34px; border-radius: 10px;
  display: flex; align-items: center; justify-content: center; margin-bottom: 2px;
}
.tp-stat-box__icon svg { width: 17px; height: 17px; }
.tp-stat-box__val { font-size: 1.6rem; font-weight: 900; letter-spacing: -.04em; line-height: 1; }
.tp-stat-box__lbl { font-size: .68rem; color: #64748b; font-weight: 500; line-height: 1.3; }

.sb-blue   .tp-stat-box__icon { background: rgba(59,130,246,.12);  color: #2563eb; }
.sb-blue   .tp-stat-box__val  { color: #2563eb; }
.sb-amber  .tp-stat-box__icon { background: rgba(245,158,11,.12);  color: #d97706; }
.sb-amber  .tp-stat-box__val  { color: #d97706; }
.sb-green  .tp-stat-box__icon { background: rgba(16,185,129,.12);  color: #059669; }
.sb-green  .tp-stat-box__val  { color: #059669; }
.sb-purple .tp-stat-box__icon { background: rgba(139,92,246,.12);  color: #7c3aed; }
.sb-purple .tp-stat-box__val  { color: #7c3aed; }

/* ─── Responsive ─────────────────────────────────────────── */
@@media (max-width: 1100px) {
  .tp-metrics__grid    { grid-template-columns: 1fr; }
  .tp-analytics__row   { grid-template-columns: 1fr; }
  .tp-stat-boxes       { grid-template-columns: repeat(2, 1fr); }
}
@@media (max-width: 600px) {
  .tp-kpi__cards  { grid-template-columns: 1fr 1fr; }
  .tp-stat-boxes  { grid-template-columns: repeat(2, 1fr); }
  .tp-card__value { font-size: 1.5rem; }
}
</style>


