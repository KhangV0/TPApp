@model TPApp.ViewModel.StepContentVm

@{
    var legalReview = Model.StepData as TPApp.Entities.LegalReviewForm;
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="fas fa-gavel"></i> Bước 6: Kiểm tra Pháp lý
        </h5>
        @if (legalReview != null)
        {
            <button class="btn btn-light btn-sm edit-step-btn" data-step="6" data-project-id="@Model.ProjectId">
                <i class="fas fa-edit"></i> Chỉnh sửa
            </button>
        }
    </div>
    <div class="card-body">
        @if (legalReview != null)
        {
            <dl class="row">
                <dt class="col-sm-3">Người kiểm tra:</dt>
                <dd class="col-sm-9"><strong>@legalReview.NguoiKiemTra</strong></dd>

                <dt class="col-sm-3">Kết quả kiểm tra:</dt>
                <dd class="col-sm-9">
                    <div class="border rounded p-2 bg-light">
                        @Html.Raw(legalReview.KetQuaKiemTra.Replace("\n", "<br />"))
                    </div>
                </dd>

                @if (!string.IsNullOrEmpty(legalReview.VanDePhapLy))
                {
                    <dt class="col-sm-3">Vấn đề pháp lý:</dt>
                    <dd class="col-sm-9">
                        <div class="alert alert-warning">
                            @Html.Raw(legalReview.VanDePhapLy.Replace("\n", "<br />"))
                        </div>
                    </dd>
                }

                @if (!string.IsNullOrEmpty(legalReview.DeXuatChinhSua))
                {
                    <dt class="col-sm-3">Đề xuất chỉnh sửa:</dt>
                    <dd class="col-sm-9">@Html.Raw(legalReview.DeXuatChinhSua.Replace("\n", "<br />"))</dd>
                }

                <dt class="col-sm-3">File kiểm tra:</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(legalReview.FileKiemTra))
                    {
                        <i class="fas fa-file-pdf text-danger"></i>
                        <strong>@System.IO.Path.GetFileName(legalReview.FileKiemTra)</strong>
                    }
                    else
                    {
                        <span class="text-muted">Chưa có file</span>
                    }
                </dd>

                <dt class="col-sm-3">Đã duyệt:</dt>
                <dd class="col-sm-9">
                    @if (legalReview.DaDuyet)
                    {
                        <span class="badge bg-success"><i class="fas fa-check"></i> Đã duyệt</span>
                    }
                    else
                    {
                        <span class="badge bg-warning"><i class="fas fa-clock"></i> Chưa duyệt</span>
                    }
                </dd>

                @if (legalReview.NgayKiemTra.HasValue)
                {
                    <dt class="col-sm-3">Ngày kiểm tra:</dt>
                    <dd class="col-sm-9">@legalReview.NgayKiemTra.Value.ToString("dd/MM/yyyy")</dd>
                }
            </dl>
        }
        else
        {
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i>
                <strong>Mô tả:</strong> Kiểm tra tính pháp lý của hợp đồng và các điều khoản
            </div>
            <p class="text-muted">Chưa có dữ liệu cho bước này.</p>
        }
    </div>
    <div class="card-footer">
        <button class="btn btn-secondary step-nav-btn" data-step="@(Model.StepNumber - 1)">
            <i class="fas fa-arrow-left"></i> Quay lại bước trước
        </button>
        @if (Model.StepNumber < 14 && Model.Steps[Model.StepNumber].IsAccessible)
        {
            <button class="btn btn-primary step-nav-btn" data-step="@(Model.StepNumber + 1)">
                Tiếp tục bước @(Model.StepNumber + 1) <i class="fas fa-arrow-right"></i>
            </button>
        }
    </div>
</div>

