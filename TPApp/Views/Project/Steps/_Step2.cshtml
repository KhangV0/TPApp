@model TPApp.ViewModel.StepContentVm

@{
    var nda = Model.StepData as TPApp.Entities.NDAAgreement;
    var eSignDoc = ViewBag.ESignDocument as TPApp.Entities.ESign.ESignDocument;
    var signatures = ViewBag.Signatures as List<TPApp.Entities.ESign.ESignSignature>;
}

<style>
    .form-control::placeholder {
        color: #ccc;
        opacity: 1;
    }
</style>

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="fas fa-file-signature"></i> Bước 2: Thỏa thuận Bảo mật (NDA) - Chữ ký điện tử
        </h5>
    </div>
    <div class="card-body">
        
        @* E-Sign Section *@
        @if (eSignDoc != null)
        {
            <div class="esign-section mb-4">
                <h6 class="border-bottom pb-2 mb-3"><i class="fas fa-shield-alt"></i> Tài liệu chữ ký điện tử</h6>
                
                <dl class="row">
                    <dt class="col-sm-3">Tên tài liệu:</dt>
                    <dd class="col-sm-9"><strong>@eSignDoc.DocumentName</strong></dd>

                    <dt class="col-sm-3">Trạng thái:</dt>
                    <dd class="col-sm-9">
                        @switch (eSignDoc.Status)
                        {
                            case 0:
                                <span class="badge bg-secondary"><i class="fas fa-file"></i> Nháp</span>
                                break;
                            case 1:
                                <span class="badge bg-warning"><i class="fas fa-clock"></i> Chờ ký</span>
                                break;
                            case 2:
                                <span class="badge bg-success"><i class="fas fa-check-circle"></i> Đã ký</span>
                                break;
                            case 3:
                                <span class="badge bg-danger"><i class="fas fa-times-circle"></i> Từ chối</span>
                                break;
                        }
                    </dd>

                    @if (!string.IsNullOrEmpty(eSignDoc.FilePath))
                    {
                        <dt class="col-sm-3">File:</dt>
                        <dd class="col-sm-9">
                            <a href="@eSignDoc.FilePath" target="_blank" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-download"></i> Tải xuống NDA
                            </a>
                        </dd>

                        <dt class="col-sm-3">Mã hash (SHA256):</dt>
                        <dd class="col-sm-9"><code class="small">@eSignDoc.FileHash</code></dd>
                    }

                    @if (eSignDoc.SignedAt.HasValue)
                    {
                        <dt class="col-sm-3">Ngày ký:</dt>
                        <dd class="col-sm-9">@eSignDoc.SignedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</dd>
                    }
                </dl>

                @* Signatures List *@
                @if (signatures != null && signatures.Any())
                {
                    <h6 class="border-bottom pb-2 mb-3 mt-4"><i class="fas fa-pen-fancy"></i> Danh sách chữ ký</h6>
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>Người ký</th>
                                    <th>Vai trò</th>
                                    <th>Trạng thái</th>
                                    <th>Ngày ký</th>
                                    <th>IP Address</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sig in signatures)
                                {
                                    <tr>
                                        <td>User #@sig.SignerUserId</td>
                                        <td>@sig.SignerRole</td>
                                        <td>
                                            @if (sig.Status == 1)
                                            {
                                                <span class="badge bg-success">Đã ký</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning">Chờ ký</span>
                                            }
                                        </td>
                                        <td>@(sig.SignedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                                        <td><small>@sig.IpAddress</small></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @* Sign Button + OTP Channel selection *@
                @if (eSignDoc.Status != 2)
                {
                    <div class="mt-4 p-3 bg-light border rounded">
                        <h6 class="mb-3"><i class="fas fa-signature"></i> Ký tài liệu điện tử</h6>
                        
                        <div id="esign-form">
                            <!-- Channel selection -->
                            <div class="mb-3">
                                <label class="form-label fw-bold">Chọn kênh nhận OTP:</label>
                                <div class="d-flex gap-4">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="ndaOtpChannel" id="ndaChannelEmail" value="email" checked>
                                        <label class="form-check-label" for="ndaChannelEmail">
                                            <i class="fas fa-envelope me-1 text-primary"></i> Email
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="ndaOtpChannel" id="ndaChannelSms" value="sms">
                                        <label class="form-check-label" for="ndaChannelSms">
                                            <i class="fas fa-sms me-1 text-success"></i> SMS
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <!-- SMS phone input (hidden by default) -->
                            <div class="mb-3" id="ndaSmsPhoneSection" style="display:none;">
                                <label class="form-label">Số điện thoại nhận OTP:</label>
                                <input type="text" class="form-control" id="ndaOtpPhoneNumber" placeholder="0912345678" />
                            </div>

                            <div class="mb-3 form-check">
                                <input type="checkbox" class="form-check-input" id="agreeTerms" />
                                <label class="form-check-label" for="agreeTerms">
                                    Tôi đã đọc và đồng ý với các điều khoản trong thỏa thuận NDA
                                </label>
                            </div>

                            <button class="btn btn-success" id="btnRequestNdaOtp" data-document-id="@eSignDoc.Id"
                                    onclick="ndaRequestOtp(this)">
                                <i class="fas fa-pen-nib me-1"></i> Gửi OTP & Ký xác nhận
                            </button>
                        </div>
                    </div>

                    <!-- OTP Verification Modal -->
                    <div class="modal fade" id="ndaOtpModal" tabindex="-1" data-bs-backdrop="static">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header bg-primary text-white">
                                    <h5 class="modal-title"><i class="fas fa-shield-alt me-2"></i>Xác nhận OTP</h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <div id="ndaOtpSentMessage" class="alert alert-info"></div>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Nhập mã OTP (6 số):</label>
                                        <input type="text" class="form-control form-control-lg text-center tracking-widest"
                                               id="ndaOtpInput" maxlength="6" placeholder="______" autocomplete="off" />
                                    </div>
                                    <div id="ndaOtpError" class="text-danger small d-none"></div>
                                </div>
                                <div class="modal-footer">
                                    <button class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                    <button class="btn btn-success" id="btnVerifyNdaOtp" onclick="ndaVerifyOtp()">
                                        <i class="fas fa-check me-1"></i> Xác nhận & Ký
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            @* No E-Sign document yet - Show combined NDA + upload form *@
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i> 
                <strong>Tạo Phiếu Thỏa thuận Bảo mật và tải lên file PDF</strong>
            </div>

            <div class="p-4 bg-light border rounded">
                <h6 class="mb-3"><i class="fas fa-file-contract"></i> Thông tin Phiếu Thỏa thuận Bảo mật</h6>
                <form id="createNdaForm" enctype="multipart/form-data">
                    <input type="hidden" id="projectId" value="@Model.ProjectId" />
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Bên A (Bên bán) <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="benA" name="benA"/>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Bên B (Bên Tư vấn) <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="benB" name="benB"/>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Loại NDA <span class="text-danger">*</span></label>
                            <select class="form-select" id="loaiNDA" name="loaiNDA" required>
                                <option value="">-- Chọn loại --</option>
                                <option value="1">Mẫu chuẩn của Sàn</option>
                                <option value="2">Tải lên mẫu riêng</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Thời hạn bảo mật <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="thoiHanBaoMat" name="thoiHanBaoMat" required 
                                   placeholder="VD: 2 năm, 36 tháng..." />
                        </div>
                    </div>

                    <hr class="my-3" />

                    <h6 class="mb-3"><i class="fas fa-upload"></i> Tải lên file PDF</h6>
                    <div class="mb-3">
                        <label class="form-label">Chọn file PDF <span class="text-danger">*</span></label>
                        <input type="file" class="form-control" id="ndaFile" name="ndaFile" accept=".pdf" required />
                        <small class="text-muted">File PDF chứa nội dung thỏa thuận bảo mật</small>
                    </div>

                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="daDongY" name="daDongY" required />
                        <label class="form-check-label" for="daDongY">
                            Tôi đã đọc và đồng ý với các điều khoản bảo mật <span class="text-danger">*</span>
                        </label>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fas fa-save"></i> Tạo Phiếu NDA và Tải lên File
                    </button>
                </form>
            </div>
        }

        @* NDA Agreement Information *@
        @if (nda != null)
        {
            <hr class="my-4" />
            <h6 class="border-bottom pb-2 mb-3"><i class="fas fa-file-contract"></i> Thông tin Phiếu Thỏa thuận Bảo mật</h6>
            <dl class="row">
                <dt class="col-sm-3">Bên A (Bên bán):</dt>
                <dd class="col-sm-9"><strong>@nda.BenA</strong></dd>

                <dt class="col-sm-3">Bên B (Bên Tư vấn):</dt>
                <dd class="col-sm-9"><strong>@nda.BenB</strong></dd>

                <dt class="col-sm-3">Loại NDA:</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-info">@nda.LoaiNDA</span>
                    <small class="text-muted ms-2">(Mẫu chuẩn của Sàn / Tải lên mẫu riêng: file @nda.LoaiNDA)</small>
                </dd>

                <dt class="col-sm-3">Thời hạn bảo mật:</dt>
                <dd class="col-sm-9">@nda.ThoiHanBaoMat</dd>

                <dt class="col-sm-3">Xác nhận ký số (E-Sign /OTP):</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(nda.XacNhanKySo))
                    {
                        <code>@nda.XacNhanKySo</code>
                    }
                    else if (eSignDoc != null && eSignDoc.Status == 2)
                    {
                        <span class="badge bg-success"><i class="fas fa-check-circle"></i> Đã ký điện tử</span>
                    }
                    else
                    {
                        <span class="text-muted">Chưa xác nhận</span>
                    }
                </dd>

                <dt class="col-sm-3">Đã đồng ý điều khoản:</dt>
                <dd class="col-sm-9">
                    @if (nda.DaDongY || (eSignDoc != null && eSignDoc.Status == 2))
                    {
                        <span class="badge bg-success"><i class="fas fa-check"></i> Đã đồng ý</span>
                    }
                    else
                    {
                        <span class="badge bg-warning"><i class="fas fa-times"></i> Chưa đồng ý</span>
                    }
                </dd>

                <dt class="col-sm-3">Ngày tạo:</dt>
                <dd class="col-sm-9">@nda.NgayTao.ToString("dd/MM/yyyy HH:mm")</dd>

                @if (nda.NgaySua.HasValue)
                {
                    <dt class="col-sm-3">Ngày cập nhật:</dt>
                    <dd class="col-sm-9">@nda.NgaySua.Value.ToString("dd/MM/yyyy HH:mm")</dd>
                }
            </dl>
        }
        else if (eSignDoc == null)
        {
            <div class="alert alert-warning mt-3">
                <i class="fas fa-exclamation-triangle"></i> 
                Chưa có thông tin phiếu thỏa thuận bảo mật. Vui lòng tải lên tài liệu NDA để bắt đầu.
            </div>
        }
    </div>
    <div class="card-footer">
        <button class="btn btn-secondary step-nav-btn" data-step="1">
            <i class="fas fa-arrow-left"></i> Quay lại bước trước
        </button>
        @if (eSignDoc != null && eSignDoc.Status == 2)
        {
            <button class="btn btn-primary step-nav-btn" data-step="3">
                Tiếp tục bước 3 <i class="fas fa-arrow-right"></i>
            </button>
        }
    </div>
</div>

<script>
(function() {
    var projectId = @Model.ProjectId;
    var ndaCountdownTimer = null;

    // ── Channel toggle ──────────────────────────────────────────────────────
    document.querySelectorAll('input[name="ndaOtpChannel"]').forEach(function(radio) {
        radio.addEventListener('change', function() {
            var smsSection = document.getElementById('ndaSmsPhoneSection');
            if (smsSection) smsSection.style.display = this.value === 'sms' ? 'block' : 'none';
        });
    });

    // ── Request OTP ─────────────────────────────────────────────────────────
    window.ndaRequestOtp = async function(btnEl) {
        var agree = document.getElementById('agreeTerms');
        if (!agree || !agree.checked) {
            alert('Vui lòng đồng ý với các điều khoản trước khi ký.');
            return;
        }

        var channel = (document.querySelector('input[name="ndaOtpChannel"]:checked') || {}).value || 'email';
        var phoneNumber = (document.getElementById('ndaOtpPhoneNumber') || {}).value || '';

        if (channel === 'sms' && !phoneNumber) {
            alert('Vui lòng nhập số điện thoại nhận OTP.');
            return;
        }

        btnEl.disabled = true;
        btnEl.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang gửi...';

        try {
            var res = await fetch('/ESign/SendOtp', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ projectId: projectId, channel: channel, phoneNumber: phoneNumber })
            });
            var data = await res.json();

            if (data.success) {
                document.getElementById('ndaOtpInput').value = '';
                document.getElementById('ndaOtpError').classList.add('d-none');
                document.getElementById('btnVerifyNdaOtp').disabled = false;
                document.getElementById('ndaOtpSentMessage').innerHTML =
                    data.message + '<br/>Có hiệu lực trong <strong id="ndaOtpCountdown" class="text-danger">5:00</strong>';
                ndaStartCountdown(300);
                new bootstrap.Modal(document.getElementById('ndaOtpModal')).show();
            } else {
                alert(data.message);
            }
        } catch (e) {
            alert('Lỗi kết nối: ' + e.message);
        } finally {
            btnEl.disabled = false;
            btnEl.innerHTML = '<i class="fas fa-pen-nib me-1"></i> Gửi OTP & Ký xác nhận';
        }
    };

    // ── Countdown timer ─────────────────────────────────────────────────────
    function ndaStartCountdown(seconds) {
        clearInterval(ndaCountdownTimer);
        var el = document.getElementById('ndaOtpCountdown');
        var remaining = seconds;

        ndaCountdownTimer = setInterval(function() {
            remaining--;
            var m = Math.floor(remaining / 60);
            var s = remaining % 60;
            el.textContent = m + ':' + s.toString().padStart(2, '0');

            if (remaining <= 0) {
                clearInterval(ndaCountdownTimer);
                el.textContent = 'Hết hạn';
                document.getElementById('btnVerifyNdaOtp').disabled = true;
                document.getElementById('ndaOtpError').textContent = 'OTP đã hết hạn. Vui lòng yêu cầu lại.';
                document.getElementById('ndaOtpError').classList.remove('d-none');
            }
        }, 1000);
    }

    // ── Verify OTP & Sign ───────────────────────────────────────────────────
    window.ndaVerifyOtp = async function() {
        var otp = document.getElementById('ndaOtpInput').value.trim();
        var errEl = document.getElementById('ndaOtpError');
        errEl.classList.add('d-none');

        if (otp.length !== 6) {
            errEl.textContent = 'Mã OTP phải 6 chữ số.';
            errEl.classList.remove('d-none');
            return;
        }

        var docId = document.getElementById('btnRequestNdaOtp').getAttribute('data-document-id');
        var btn = document.getElementById('btnVerifyNdaOtp');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang xác nhận...';

        try {
            var res = await fetch('/ESign/SignDocument', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ documentId: parseInt(docId), otpCode: otp })
            });
            var data = await res.json();

            if (data.success) {
                clearInterval(ndaCountdownTimer);
                bootstrap.Modal.getInstance(document.getElementById('ndaOtpModal'))?.hide();
                alert('✅ ' + data.message);
                // Redirect to step 3 after successful signing
                window.location.href = '/Project/Details/' + projectId + '?step=3';
            } else {
                errEl.textContent = data.message;
                errEl.classList.remove('d-none');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-check me-1"></i> Xác nhận & Ký';
            }
        } catch (e) {
            errEl.textContent = 'Lỗi kết nối: ' + e.message;
            errEl.classList.remove('d-none');
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-check me-1"></i> Xác nhận & Ký';
        }
    };
})();

// ── Create NDA form submission ──────────────────────────────────────────────
document.getElementById('createNdaForm')?.addEventListener('submit', async function(e) {
    e.preventDefault();
    var form = new FormData();
    form.append('projectId', document.getElementById('projectId')?.value || '');
    form.append('benA', document.getElementById('benA')?.value || '');
    form.append('benB', document.getElementById('benB')?.value || '');
    form.append('loaiNDA', document.getElementById('loaiNDA')?.value || '');
    form.append('thoiHanBaoMat', document.getElementById('thoiHanBaoMat')?.value || '');
    form.append('daDongY', document.getElementById('daDongY')?.checked ? 'true' : 'false');

    var fileInput = document.getElementById('ndaFile');
    if (fileInput && fileInput.files.length > 0) {
        form.append('ndaFile', fileInput.files[0]);
    } else {
        alert('Vui lòng chọn file PDF.');
        return;
    }

    try {
        var res = await fetch('/ESign/UploadNda', { method: 'POST', body: form });
        var data = await res.json();
        if (data.success) {
            alert('✅ ' + data.message);
            location.reload();
        } else {
            alert('❌ ' + data.message);
        }
    } catch(ex) {
        alert('Lỗi: ' + ex.message);
    }
});
</script>
