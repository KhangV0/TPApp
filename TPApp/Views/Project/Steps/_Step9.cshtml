@model TPApp.ViewModel.StepContentVm

@{
    var pilotTest = Model.StepData as TPApp.Entities.PilotTestReport;
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="fas fa-flask"></i> Bước 9: Thử nghiệm Pilot
        </h5>
        @if (pilotTest != null)
        {
            <button class="btn btn-light btn-sm edit-step-btn" data-step="9" data-project-id="@Model.ProjectId">
                <i class="fas fa-edit"></i> Chỉnh sửa
            </button>
        }
    </div>
    <div class="card-body">
        @if (pilotTest != null)
        {
            <dl class="row">
                <dt class="col-sm-3">Mô tả thử nghiệm:</dt>
                <dd class="col-sm-9">
                    <div class="border rounded p-2 bg-light">
                        @Html.Raw(pilotTest.MoTaThuNghiem.Replace("\n", "<br />"))
                    </div>
                </dd>

                <dt class="col-sm-3">Kết quả thử nghiệm:</dt>
                <dd class="col-sm-9">
                    <div class="border rounded p-2 bg-light">
                        @Html.Raw(pilotTest.KetQuaThuNghiem.Replace("\n", "<br />"))
                    </div>
                </dd>

                @if (!string.IsNullOrEmpty(pilotTest.VanDePhatSinh))
                {
                    <dt class="col-sm-3">Vấn đề phát sinh:</dt>
                    <dd class="col-sm-9">
                        <div class="alert alert-warning">
                            @Html.Raw(pilotTest.VanDePhatSinh.Replace("\n", "<br />"))
                        </div>
                    </dd>
                }

                @if (!string.IsNullOrEmpty(pilotTest.GiaiPhap))
                {
                    <dt class="col-sm-3">Giải pháp:</dt>
                    <dd class="col-sm-9">@Html.Raw(pilotTest.GiaiPhap.Replace("\n", "<br />"))</dd>
                }

                <dt class="col-sm-3">Đạt yêu cầu:</dt>
                <dd class="col-sm-9">
                    @if (pilotTest.DatYeuCau)
                    {
                        <span class="badge bg-success"><i class="fas fa-check"></i> Đạt yêu cầu</span>
                    }
                    else
                    {
                        <span class="badge bg-danger"><i class="fas fa-times"></i> Chưa đạt</span>
                    }
                </dd>

                @if (pilotTest.NgayBatDau.HasValue)
                {
                    <dt class="col-sm-3">Ngày bắt đầu:</dt>
                    <dd class="col-sm-9">@pilotTest.NgayBatDau.Value.ToString("dd/MM/yyyy")</dd>
                }

                @if (pilotTest.NgayKetThuc.HasValue)
                {
                    <dt class="col-sm-3">Ngày kết thúc:</dt>
                    <dd class="col-sm-9">@pilotTest.NgayKetThuc.Value.ToString("dd/MM/yyyy")</dd>
                }

                <dt class="col-sm-3">File kết quả:</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(pilotTest.FileKetQua))
                    {
                        <i class="fas fa-file text-primary"></i>
                        <strong>@System.IO.Path.GetFileName(pilotTest.FileKetQua)</strong>
                    }
                    else
                    {
                        <span class="text-muted">Chưa có file</span>
                    }
                </dd>
            </dl>
        }
        else
        {
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i>
                <strong>Mô tả:</strong> Thử nghiệm pilot để đánh giá hiệu quả trước khi triển khai chính thức
            </div>
            <p class="text-muted">Chưa có dữ liệu cho bước này.</p>
        }
    </div>
    <div class="card-footer">
        <button class="btn btn-secondary step-nav-btn" data-step="@(Model.StepNumber - 1)">
            <i class="fas fa-arrow-left"></i> Quay lại bước trước
        </button>
        @if (Model.StepNumber < 14 && Model.Steps[Model.StepNumber].IsAccessible)
        {
            <button class="btn btn-primary step-nav-btn" data-step="@(Model.StepNumber + 1)">
                Tiếp tục bước @(Model.StepNumber + 1) <i class="fas fa-arrow-right"></i>
            </button>
        }
    </div>
</div>

