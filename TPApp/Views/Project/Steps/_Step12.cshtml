@model TPApp.ViewModel.StepContentVm

@{
    var techDoc = Model.StepData as TPApp.Entities.TechnicalDocHandover;
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="fas fa-file-code"></i> Bước 12: Bàn giao Hồ sơ Kỹ thuật
        </h5>
        @if (techDoc != null)
        {
            <button class="btn btn-light btn-sm edit-step-btn" data-step="12" data-project-id="@Model.ProjectId">
                <i class="fas fa-edit"></i> Chỉnh sửa
            </button>
        }
    </div>
    <div class="card-body">
        @if (techDoc != null)
        {
            <dl class="row">
                <dt class="col-sm-3">Source Code:</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(techDoc.SourceCode))
                    {
                        <i class="fas fa-code text-success"></i>
                        <strong>@techDoc.SourceCode</strong>
                    }
                    else
                    {
                        <span class="text-muted">Chưa có</span>
                    }
                </dd>

                <dt class="col-sm-3">Tài liệu kỹ thuật:</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(techDoc.TaiLieuKyThuat))
                    {
                        <i class="fas fa-file-pdf text-danger"></i>
                        <strong>@System.IO.Path.GetFileName(techDoc.TaiLieuKyThuat)</strong>
                    }
                    else
                    {
                        <span class="text-muted">Chưa có file</span>
                    }
                </dd>

                <dt class="col-sm-3">Tài liệu hướng dẫn sử dụng:</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(techDoc.TaiLieuHuongDanSuDung))
                    {
                        <i class="fas fa-book text-primary"></i>
                        <strong>@System.IO.Path.GetFileName(techDoc.TaiLieuHuongDanSuDung)</strong>
                    }
                    else
                    {
                        <span class="text-muted">Chưa có file</span>
                    }
                </dd>

                <dt class="col-sm-3">Tài liệu bảo trì:</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(techDoc.TaiLieuBaoTri))
                    {
                        <i class="fas fa-tools text-warning"></i>
                        <strong>@System.IO.Path.GetFileName(techDoc.TaiLieuBaoTri)</strong>
                    }
                    else
                    {
                        <span class="text-muted">Chưa có file</span>
                    }
                </dd>

                <dt class="col-sm-3">Database:</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(techDoc.Database))
                    {
                        <i class="fas fa-database text-info"></i>
                        <strong>@techDoc.Database</strong>
                    }
                    else
                    {
                        <span class="text-muted">Chưa có</span>
                    }
                </dd>

                @if (!string.IsNullOrEmpty(techDoc.GhiChu))
                {
                    <dt class="col-sm-3">Ghi chú:</dt>
                    <dd class="col-sm-9">
                        <div class="border rounded p-2 bg-light">
                            @Html.Raw(techDoc.GhiChu.Replace("\n", "<br />"))
                        </div>
                    </dd>
                }

                <dt class="col-sm-3">Đã bàn giao đầy đủ:</dt>
                <dd class="col-sm-9">
                    @if (techDoc.DaBanGiaoDayDu)
                    {
                        <span class="badge bg-success"><i class="fas fa-check"></i> Đã bàn giao đầy đủ</span>
                    }
                    else
                    {
                        <span class="badge bg-warning"><i class="fas fa-clock"></i> Chưa đầy đủ</span>
                    }
                </dd>

                @if (techDoc.NgayBanGiao.HasValue)
                {
                    <dt class="col-sm-3">Ngày bàn giao:</dt>
                    <dd class="col-sm-9">@techDoc.NgayBanGiao.Value.ToString("dd/MM/yyyy")</dd>
                }
            </dl>
        }
        else
        {
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i>
                <strong>Mô tả:</strong> Bàn giao đầy đủ hồ sơ kỹ thuật, source code, tài liệu và database
            </div>
            <p class="text-muted">Chưa có dữ liệu cho bước này.</p>
        }
    </div>
    <div class="card-footer">
        <button class="btn btn-secondary step-nav-btn" data-step="@(Model.StepNumber - 1)">
            <i class="fas fa-arrow-left"></i> Quay lại bước trước
        </button>
        @if (Model.StepNumber < 14 && Model.Steps[Model.StepNumber].IsAccessible)
        {
            <button class="btn btn-primary step-nav-btn" data-step="@(Model.StepNumber + 1)">
                Tiếp tục bước @(Model.StepNumber + 1) <i class="fas fa-arrow-right"></i>
            </button>
        }
    </div>
</div>

