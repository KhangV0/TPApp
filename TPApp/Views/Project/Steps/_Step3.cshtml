@model TPApp.ViewModel.StepContentVm

@{
    var rfq = Model.StepData as TPApp.Entities.RFQRequest;
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="fas fa-file-invoice"></i> Bước 3: Yêu cầu Báo giá (RFQ)
        </h5>
    </div>
    <div class="card-body">
        @if (rfq != null)
        {
            <h6 class="border-bottom pb-2 mb-3"><i class="fas fa-file-invoice"></i> Thông tin Yêu cầu Báo giá</h6>
            <dl class="row">
                <dt class="col-sm-3">Mã RFQ:</dt>
                <dd class="col-sm-9"><strong>@rfq.MaRFQ</strong></dd>

                <dt class="col-sm-3">Yêu cầu kỹ thuật:</dt>
                <dd class="col-sm-9">
                    <div class="border rounded p-3 bg-light">
                        @Html.Raw(rfq.YeuCauKyThuat.Replace("\n", "<br />"))
                    </div>
                </dd>

                <dt class="col-sm-3">Tiêu chuẩn nghiệm thu:</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(rfq.TieuChuanNghiemThu))
                    {
                        <div class="border rounded p-3 bg-light">
                            @Html.Raw(rfq.TieuChuanNghiemThu.Replace("\n", "<br />"))
                        </div>
                    }
                    else
                    {
                        <span class="text-muted">Chưa cập nhật</span>
                    }
                </dd>

                <dt class="col-sm-3">Hạn chót nộp hồ sơ:</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-danger">
                        <i class="fas fa-calendar-alt"></i> @rfq.HanChotNopHoSo.ToString("dd/MM/yyyy")
                    </span>
                </dd>

                <dt class="col-sm-3">Đã gửi nhà cung ứng:</dt>
                <dd class="col-sm-9">
                    @if (rfq.DaGuiNhaCungUng)
                    {
                        <span class="badge bg-success"><i class="fas fa-check"></i> Đã gửi</span>
                    }
                    else
                    {
                        <span class="badge bg-warning"><i class="fas fa-times"></i> Chưa gửi</span>
                    }
                </dd>

                <dt class="col-sm-3">Trạng thái:</dt>
                <dd class="col-sm-9">
                    @if (Model.Steps[2].StatusId > 0)
                    {
                        <span class="badge bg-success"><i class="fas fa-check"></i> Đã hoàn thành</span>
                    }
                    else
                    {
                        <span class="badge bg-warning"><i class="fas fa-clock"></i> Chưa hoàn thành</span>
                    }
                </dd>

                <dt class="col-sm-3">Ngày tạo:</dt>
                <dd class="col-sm-9">@rfq.NgayTao.ToString("dd/MM/yyyy HH:mm")</dd>

                @if (rfq.NgaySua.HasValue)
                {
                    <dt class="col-sm-3">Ngày cập nhật:</dt>
                    <dd class="col-sm-9">@rfq.NgaySua.Value.ToString("dd/MM/yyyy HH:mm")</dd>
                }
            </dl>

            @* Invited Suppliers List *@
            @if (ViewBag.InvitedSuppliers != null && ((IEnumerable<dynamic>)ViewBag.InvitedSuppliers).Any())
            {
                <hr class="my-4" />
                <div class="mb-4">
                    <h6 class="mb-3"><i class="fas fa-users"></i> Nhà cung ứng đã được mời</h6>
                    <div class="table-responsive">
                        <table class="table table-sm table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Nhà cung ứng</th>
                                    <th>Liên hệ</th>
                                    <th>Ngày mời</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var invited in (IEnumerable<dynamic>)ViewBag.InvitedSuppliers)
                                {
                                    <tr>
                                        <td><strong>@invited.FullName</strong></td>
                                        <td>
                                            <small>
                                                @if (!string.IsNullOrEmpty(invited.Email))
                                                {
                                                    <div><i class="fas fa-envelope"></i> @invited.Email</div>
                                                }
                                                @if (!string.IsNullOrEmpty(invited.Phone))
                                                {
                                                    <div><i class="fas fa-phone"></i> @invited.Phone</div>
                                                }
                                            </small>
                                        </td>
                                        <td><small>@invited.InvitedDate.ToString("dd/MM/yyyy HH:mm")</small></td>
                                        <td>
                                            @{
                                                // Check if seller has submitted proposal
                                                var hasProposal = invited.HasProposal;
                                                
                                                string statusText;
                                                string badgeClass;
                                                
                                                if (hasProposal)
                                                {
                                                    statusText = "Đã gửi báo giá";
                                                    badgeClass = "bg-success";
                                                }
                                                else
                                                {
                                                    statusText = invited.StatusId switch
                                                    {
                                                        0 => "Chờ phản hồi",
                                                        1 => "Đã xem",
                                                        2 => "Đã chấp nhận",
                                                        3 => "Đã từ chối",
                                                        _ => "Không xác định"
                                                    };
                                                    badgeClass = invited.StatusId switch
                                                    {
                                                        0 => "bg-warning",
                                                        1 => "bg-info",
                                                        2 => "bg-success",
                                                        3 => "bg-secondary",
                                                        _ => "bg-light"
                                                    };
                                                }
                                            }
                                            <span class="badge @badgeClass">@statusText</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @* Send to More Suppliers Section *@
            <hr class="my-4" />
            <div class="p-3 bg-light border rounded">
                <h6 class="mb-3"><i class="fas fa-paper-plane"></i> Gửi yêu cầu đến nhà cung ứng @(ViewBag.InvitedSuppliers != null && ((IEnumerable<dynamic>)ViewBag.InvitedSuppliers).Any() ? "khác" : "")</h6>
                <p class="text-muted">Chọn các nhà cung ứng để gửi yêu cầu báo giá. Họ sẽ nhận được thông báo và có thể xem chi tiết RFQ sau khi ký NDA.</p>
                
                <form method="post" action="/RFQ/SendToSuppliers/@rfq.Id" id="sendRfqForm">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-3">
                        <label class="form-label"><strong>Chọn nhà cung ứng:</strong></label>
                        <div class="seller-selection border rounded p-3 bg-white" style="max-height: 300px; overflow-y: auto;">
                            @if (ViewBag.AvailableSuppliers != null && ((IEnumerable<dynamic>)ViewBag.AvailableSuppliers).Any())
                            {
                                var invitedIds = ViewBag.InvitedSuppliers != null 
                                    ? ((IEnumerable<dynamic>)ViewBag.InvitedSuppliers).Select(i => (int)i.SellerId).ToList()
                                    : new List<int>();
                                
                                @foreach (var seller in (IEnumerable<dynamic>)ViewBag.AvailableSuppliers)
                                {
                                    var alreadyInvited = invitedIds.Contains((int)seller.UserId);
                                    <div class="form-check mb-2 @(alreadyInvited ? "text-muted" : "")">
                                        <input type="checkbox" name="selectedSellerIds" 
                                               value="@seller.UserId" 
                                               class="form-check-input seller-checkbox" 
                                               id="seller_@seller.UserId"
                                               @(alreadyInvited ? "disabled" : "") />
                                        <label class="form-check-label" for="seller_@seller.UserId">
                                            <strong>@seller.FullName</strong>
                                            @if (alreadyInvited)
                                            {
                                                <span class="badge bg-secondary ms-2">Đã mời</span>
                                            }
                                            <br />
                                            <small class="text-muted">
                                                @if (!string.IsNullOrEmpty(seller.Email))
                                                {
                                                    <i class="fas fa-envelope"></i> @seller.Email
                                                }
                                                @if (!string.IsNullOrEmpty(seller.Phone))
                                                {
                                                    <span class="ms-2"><i class="fas fa-phone"></i> @seller.Phone</span>
                                                }
                                                @if (!string.IsNullOrEmpty(seller.UserName))
                                                {
                                                    <span class="ms-2"><i class="fas fa-user"></i> @seller.UserName</span>
                                                }
                                            </small>
                                        </label>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="alert alert-warning mb-0">
                                    <i class="fas fa-exclamation-triangle"></i> 
                                    <strong>Chưa có nhà cung ứng nào trong hệ thống</strong><br />
                                    Vui lòng liên hệ quản trị viên để thêm nhà cung ứng.
                                </div>
                            }
                        </div>
                        <small class="text-muted">Chọn ít nhất một nhà cung ứng để gửi RFQ</small>
                    </div>
                    
                    <button type="submit" class="btn btn-success" id="btnSendRfq">
                        <i class="fas fa-paper-plane"></i> Gửi đến nhà cung ứng đã chọn
                    </button>
                </form>
            </div>
            
            <script>
                // Validate at least one supplier is selected
                document.getElementById('sendRfqForm')?.addEventListener('submit', function(e) {
                    const checkboxes = document.querySelectorAll('.seller-checkbox:checked:not([disabled])');
                    if (checkboxes.length === 0) {
                        e.preventDefault();
                        showToast('warning', 'Vui lòng chọn ít nhất một nhà cung ứng!');
                        return false;
                    }
                });
            </script>
        }
        else
        {
            @* No RFQ yet - Show creation form *@
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i> 
                <strong>Tạo Yêu cầu Báo giá (RFQ)</strong>
            </div>

            <div class="p-4 bg-light border rounded">
                <h6 class="mb-3"><i class="fas fa-file-invoice"></i> Thông tin Yêu cầu Báo giá</h6>
                <form id="createRfqForm" method="post" action="/RFQ/Create">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ProjectId" value="@Model.ProjectId" />
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Mã RFQ <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="MaRFQ" id="maRFQ" required 
                                   placeholder="VD: RFQ-2026-001" />
                            <small class="text-muted">Mã định danh duy nhất cho yêu cầu báo giá</small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Hạn chót nộp hồ sơ <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" name="HanChotNopHoSo" id="hanChotNopHoSo" required />
                            <small class="text-muted">Ngày cuối cùng nhà cung ứng có thể nộp báo giá</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Yêu cầu kỹ thuật <span class="text-danger">*</span></label>
                        <textarea class="form-control" name="YeuCauKyThuat" id="yeuCauKyThuat" rows="6" required
                                  placeholder="Mô tả chi tiết các yêu cầu kỹ thuật cho sản phẩm/dịch vụ..."></textarea>
                        <small class="text-muted">Mô tả chi tiết các yêu cầu kỹ thuật, thông số kỹ thuật, tiêu chuẩn cần đáp ứng</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tiêu chuẩn nghiệm thu</label>
                        <textarea class="form-control" name="TieuChuanNghiemThu" id="tieuChuanNghiemThu" rows="4"
                                  placeholder="Mô tả các tiêu chuẩn nghiệm thu sản phẩm/dịch vụ..."></textarea>
                        <small class="text-muted">Các tiêu chí đánh giá và nghiệm thu sản phẩm/dịch vụ (không bắt buộc)</small>
                    </div>

                    <hr class="my-3" />

                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="xacNhanThongTin" required />
                        <label class="form-check-label" for="xacNhanThongTin">
                            Tôi xác nhận các thông tin trên là chính xác và đầy đủ <span class="text-danger">*</span>
                        </label>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fas fa-save"></i> Tạo Yêu cầu Báo giá
                    </button>
                </form>
            </div>
        }
    </div>
    <div class="card-footer">
        <button class="btn btn-secondary step-nav-btn" data-step="@(Model.StepNumber - 1)">
            <i class="fas fa-arrow-left"></i> Quay lại bước trước
        </button>
        @if (rfq != null && Model.StepNumber < 11 && Model.Steps[Model.StepNumber].IsAccessible)
        {
            <button class="btn btn-primary step-nav-btn" data-step="@(Model.StepNumber + 1)">
                Tiếp tục bước @(Model.StepNumber + 1) <i class="fas fa-arrow-right"></i>
            </button>
        }
    </div>
</div>

<script>
    // Set minimum date to today for deadline picker
    document.addEventListener('DOMContentLoaded', function() {
        const dateInput = document.getElementById('hanChotNopHoSo');
        if (dateInput) {
            const today = new Date().toISOString().split('T')[0];
            dateInput.setAttribute('min', today);
        }
    });
</script>

