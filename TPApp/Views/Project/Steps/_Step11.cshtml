@model TPApp.ViewModel.StepContentVm

@{
    var training = Model.StepData as TPApp.Entities.TrainingHandover;
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="fas fa-chalkboard-teacher"></i> Bước 11: Đào tạo & Chuyển giao Vận hành
        </h5>
        @if (training != null)
        {
            <button class="btn btn-light btn-sm edit-step-btn" data-step="11" data-project-id="@Model.ProjectId">
                <i class="fas fa-edit"></i> Chỉnh sửa
            </button>
        }
    </div>
    <div class="card-body">
        @if (training != null)
        {
            <dl class="row">
                <dt class="col-sm-3">Nội dung đào tạo:</dt>
                <dd class="col-sm-9">
                    <div class="border rounded p-2 bg-light">
                        @Html.Raw(training.NoiDungDaoTao.Replace("\n", "<br />"))
                    </div>
                </dd>

                @if (training.SoNguoiThamGia.HasValue)
                {
                    <dt class="col-sm-3">Số người tham gia:</dt>
                    <dd class="col-sm-9">
                        <span class="badge bg-info fs-6">
                            <i class="fas fa-users"></i> @training.SoNguoiThamGia.Value người
                        </span>
                    </dd>
                }

                @if (training.SoGioDaoTao.HasValue)
                {
                    <dt class="col-sm-3">Số giờ đào tạo:</dt>
                    <dd class="col-sm-9">
                        <span class="badge bg-primary fs-6">
                            <i class="fas fa-clock"></i> @training.SoGioDaoTao.Value giờ
                        </span>
                    </dd>
                }

                <dt class="col-sm-3">Tài liệu đào tạo:</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(training.TaiLieuDaoTao))
                    {
                        <i class="fas fa-file-pdf text-danger"></i>
                        <strong>@System.IO.Path.GetFileName(training.TaiLieuDaoTao)</strong>
                    }
                    else
                    {
                        <span class="text-muted">Chưa có file</span>
                    }
                </dd>

                <dt class="col-sm-3">Video hướng dẫn:</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(training.VideoHuongDan))
                    {
                        <i class="fas fa-video text-primary"></i>
                        <strong>@System.IO.Path.GetFileName(training.VideoHuongDan)</strong>
                    }
                    else
                    {
                        <span class="text-muted">Chưa có video</span>
                    }
                </dd>

                <dt class="col-sm-3">Đã hoàn thành:</dt>
                <dd class="col-sm-9">
                    @if (training.DaHoanThanh)
                    {
                        <span class="badge bg-success"><i class="fas fa-check"></i> Đã hoàn thành</span>
                    }
                    else
                    {
                        <span class="badge bg-warning"><i class="fas fa-clock"></i> Đang thực hiện</span>
                    }
                </dd>

                @if (training.NgayBatDau.HasValue)
                {
                    <dt class="col-sm-3">Ngày bắt đầu:</dt>
                    <dd class="col-sm-9">@training.NgayBatDau.Value.ToString("dd/MM/yyyy")</dd>
                }

                @if (training.NgayKetThuc.HasValue)
                {
                    <dt class="col-sm-3">Ngày kết thúc:</dt>
                    <dd class="col-sm-9">@training.NgayKetThuc.Value.ToString("dd/MM/yyyy")</dd>
                }
            </dl>
        }
        else
        {
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i>
                <strong>Mô tả:</strong> Đào tạo đội ngũ vận hành và chuyển giao kiến thức
            </div>
            <p class="text-muted">Chưa có dữ liệu cho bước này.</p>
        }
    </div>
    <div class="card-footer">
        <button class="btn btn-secondary step-nav-btn" data-step="@(Model.StepNumber - 1)">
            <i class="fas fa-arrow-left"></i> Quay lại bước trước
        </button>
        @if (Model.StepNumber < 14 && Model.Steps[Model.StepNumber].IsAccessible)
        {
            <button class="btn btn-primary step-nav-btn" data-step="@(Model.StepNumber + 1)">
                Tiếp tục bước @(Model.StepNumber + 1) <i class="fas fa-arrow-right"></i>
            </button>
        }
    </div>
</div>

