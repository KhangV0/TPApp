@using TPApp.ViewModel
@using TPApp.Entities
@model ProductDetailViewModel

@{
    var p = Model.Product;
    var supplier = (p.NCUId != null)
        ? Model.Suppliers?.FirstOrDefault(s => s.CungUngId == p.NCUId)
        : null;

    var catIds = new List<int>();
    if (!string.IsNullOrEmpty(p.CategoryId))
    {
        foreach (var s in p.CategoryId.Split(new[]{',','|',';'}, StringSplitOptions.RemoveEmptyEntries))
        {
            if (int.TryParse(s.Trim(), out int cid)) catIds.Add(cid);
        }
    }

    Func<bool, string> chk = (v) => v ? "☑" : "☐";
}

<style>
.hscn-section-title {
    background: #1a5276;
    color: #fff;
    padding: 7px 14px;
    font-weight: 700;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 14px;
    border-radius: 3px;
}
.hscn-item { margin-bottom: 14px; }
.hscn-item-title {
    font-weight: 700;
    color: #1a5276;
    margin-bottom: 5px;
    font-size: 13.5px;
}
.hscn-item-title .num { display: inline-block; min-width: 26px; }
.hscn-check-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-bottom: 3px;
    font-size: 13.5px;
}
.hscn-table-info td { border: none; padding: 3px 10px 3px 0; }
.hscn-table-info td:first-child { font-weight: 700; min-width: 170px; color: #444; white-space: nowrap; }
.content-body img  { max-width: 100%; height: auto; }
.content-body table { width: 100%; }
</style>

@await Html.PartialAsync("_DetailHeader", Model)

<div class="ho-so-cong-nghe mt-4">

    @* TAB NAVIGATION *@
    <ul class="nav nav-tabs" id="detailTabsThietBi" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="tb-nhandienTab" data-bs-toggle="tab"
                    data-bs-target="#tb-nhandien" type="button" role="tab">
                <i class="fa fa-id-card me-1"></i>Nhận diện thiết bị
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="tb-thongsoTab" data-bs-toggle="tab"
                    data-bs-target="#tb-thongso" type="button" role="tab">
                <i class="fa fa-cogs me-1"></i>Thông số kỹ thuật
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="tb-uudiemgiaTab" data-bs-toggle="tab"
                    data-bs-target="#tb-uudiemgia" type="button" role="tab">
                <i class="fa fa-star me-1"></i>Ưu điểm &amp; Giá
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="tb-nhacungungTab" data-bs-toggle="tab"
                    data-bs-target="#tb-nhacungung" type="button" role="tab">
                <i class="fa fa-building me-1"></i>Nhà cung ứng
            </button>
        </li>
    </ul>

    <div class="tab-content border border-top-0 rounded-bottom p-4" id="detailTabsThietBiContent">

        @* ══════════════════════════════════════
           TAB 1 – NHẬN DIỆN THIẾT BỊ
           ══════════════════════════════════════ *@
        <div class="tab-pane fade show active" id="tb-nhandien" role="tabpanel">
            <div class="hscn-section-title"><i class="fa fa-id-card me-2"></i>Thông tin nhận diện thiết bị</div>

            @* 1. Tên thiết bị *@
            <div class="hscn-item">
                <div class="hscn-item-title"><span class="num">1.</span> Tên thiết bị / máy móc</div>
                <div class="ps-3 fw-bold fs-6">@p.Name</div>
            </div>

            @* 2. Ảnh đại diện *@
            @if (!string.IsNullOrEmpty(p.QuyTrinhHinhAnh))
            {
                <div class="hscn-item">
                    <div class="hscn-item-title"><span class="num">2.</span> Ảnh đại diện thiết bị</div>
                    <div class="ps-3">
                        <img src="@Html.CookedImageURL("org", p.QuyTrinhHinhAnh)"
                             alt="@p.Name"
                             style="max-width:320px; max-height:240px; object-fit:contain; border:1px solid #ddd; padding:4px;" />
                    </div>
                </div>
            }

            @* 3. Xuất xứ *@
            <div class="hscn-item">
                <div class="hscn-item-title"><span class="num">3.</span> Xuất xứ</div>
                <div class="ps-3">
                    @{
                        bool isDomestic = string.IsNullOrEmpty(p.XuatXu) ||
                            p.XuatXu.Contains("Việt", StringComparison.OrdinalIgnoreCase) ||
                            p.XuatXu.Contains("VN", StringComparison.OrdinalIgnoreCase);
                    }
                    <div class="hscn-check-row">@chk(isDomestic) Trong nước (Việt Nam)</div>
                    <div class="hscn-check-row">@chk(!isDomestic) Nước ngoài
                        @if (!isDomestic && !string.IsNullOrEmpty(p.XuatXu))
                        {
                            <span>(Quốc gia: <strong>@p.XuatXu</strong>)</span>
                        }
                    </div>
                </div>
            </div>

            @* 4. Lĩnh vực áp dụng *@
            <div class="hscn-item">
                <div class="hscn-item-title"><span class="num">4.</span> Lĩnh vực áp dụng</div>
                <div class="ps-3">
                    @if (Model.Industries != null && Model.Industries.Any())
                    {
                        @foreach (var ind in Model.Industries)
                        {
                            <div class="hscn-check-row">@chk(catIds.Contains(ind.CatId)) @ind.Title</div>
                        }
                    }
                    else if (!string.IsNullOrEmpty(Model.CategoryTitle))
                    {
                        <div class="hscn-check-row">☑ @Model.CategoryTitle</div>
                    }
                    else { <span class="text-muted">—</span> }
                </div>
            </div>

            @* 5. Mức độ phát triển (Rating) *@
            <div class="hscn-item">
                <div class="hscn-item-title"><span class="num">5.</span> Mức độ phát triển</div>
                <div class="ps-3">
                    <div class="hscn-check-row">@chk(p.Rating == 7) <i class="fa fa-flask me-1"></i> Đã ứng dụng thử nghiệm (Pilot)</div>
                    <div class="hscn-check-row">@chk(p.Rating == 8) <i class="fa fa-industry me-1"></i> Đã ứng dụng công nghiệp</div>
                    <div class="hscn-check-row">@chk(p.Rating == 9) <i class="fa fa-shopping-cart me-1"></i> Đã thương mại hóa</div>
                    @if (p.DaBan.HasValue && p.DaBan > 0)
                    {
                        <div class="mt-1 text-muted small">Đã bán: <strong>@p.DaBan</strong> đơn vị</div>
                    }
                    @if (p.TinhTrangHang.HasValue)
                    {
                        <div class="mt-1">
                            Tình trạng hàng:
                            @if (p.TinhTrangHang == 1)
                            {
                                <span class="badge bg-success">Còn hàng</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Hết hàng</span>
                            }
                        </div>
                    }
                </div>
            </div>

            @* Keywords *@
            @if (Model.Keywords != null && Model.Keywords.Any())
            {
                <div class="hscn-item">
                    <div class="hscn-item-title">Từ khoá</div>
                    <div class="ps-3">
                        @foreach (var kw in Model.Keywords)
                        {
                            <span class="badge bg-secondary me-1">@kw.Keyword</span>
                        }
                    </div>
                </div>
            }
        </div>

        @* ══════════════════════════════════════
           TAB 2 – THÔNG SỐ KỸ THUẬT & VẬN HÀNH
           ══════════════════════════════════════ *@
        <div class="tab-pane fade" id="tb-thongso" role="tabpanel">
            <div class="hscn-section-title"><i class="fa fa-cogs me-2"></i>Thông số kỹ thuật &amp; Vận hành</div>

            @* 6. Thông số kỹ thuật chính *@
            <div class="hscn-item">
                <div class="hscn-item-title"><span class="num">6.</span> Thông số kỹ thuật chính</div>
                <div class="ps-3 content-body">
                    @if (!string.IsNullOrEmpty(p.ThongSo)) { @Html.Raw(p.ThongSo) }
                    else { <span class="text-muted">—</span> }
                </div>
            </div>

            @* 7. Nguyên lý hoạt động *@
            <div class="hscn-item">
                <div class="hscn-item-title"><span class="num">7.</span> Mô tả nguyên lý hoạt động</div>
                <div class="ps-3 content-body">
                    @if (!string.IsNullOrEmpty(p.MoTa)) { @Html.Raw(p.MoTa) }
                    else { <span class="text-muted">—</span> }
                </div>
            </div>

            @* 8. Video vận hành *@
            <div class="hscn-item">
                <div class="hscn-item-title"><span class="num">8.</span> Video vận hành</div>
                <div class="ps-3">
                    @{
                        string embedUrl = null;
                        if (!string.IsNullOrEmpty(Model.YoutubeEmbedUrl))
                        {
                            embedUrl = Model.YoutubeEmbedUrl;
                        }
                        else if (!string.IsNullOrEmpty(p.URL))
                        {
                            var rawUrl = p.URL.Trim();
                            if (rawUrl.Contains("youtube.com/embed/"))
                            {
                                embedUrl = rawUrl;
                            }
                            else if (rawUrl.Contains("youtube.com/watch"))
                            {
                                var vIdx = rawUrl.IndexOf("v=");
                                if (vIdx >= 0)
                                {
                                    var vid = rawUrl.Substring(vIdx + 2);
                                    var ampIdx = vid.IndexOf('&');
                                    if (ampIdx >= 0) vid = vid.Substring(0, ampIdx);
                                    embedUrl = $"https://www.youtube.com/embed/{vid}";
                                }
                            }
                            else if (rawUrl.Contains("youtu.be/"))
                            {
                                var parts = rawUrl.Split(new[] { "youtu.be/" }, StringSplitOptions.None);
                                if (parts.Length > 1)
                                {
                                    var vid = parts[1].Split('?')[0];
                                    embedUrl = $"https://www.youtube.com/embed/{vid}";
                                }
                            }
                        }
                    }
                    @if (!string.IsNullOrEmpty(embedUrl))
                    {
                        <div class="ratio ratio-16x9" style="max-width:640px;">
                            <iframe src="@embedUrl"
                                    title="@p.Name"
                                    allowfullscreen
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
                            </iframe>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(Model.VideoFileUrl))
                    {
                        <a href="@Model.VideoFileUrl" target="_blank" class="btn btn-sm btn-outline-danger">
                            <i class="fa fa-play me-1"></i> Xem video
                        </a>
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </div>
            </div>
        </div>

        @* ══════════════════════════════════════
           TAB 3 – ƯU ĐIỂM & GIÁ
           ══════════════════════════════════════ *@
        <div class="tab-pane fade" id="tb-uudiemgia" role="tabpanel">
            <div class="hscn-section-title"><i class="fa fa-star me-2"></i>Ưu điểm &amp; Giá bán</div>

            @* 9. Ưu điểm nổi bật *@
            <div class="hscn-item">
                <div class="hscn-item-title"><span class="num">9.</span> Ưu điểm nổi bật</div>
                <div class="ps-3 content-body">
                    @if (!string.IsNullOrEmpty(p.UuDiem)) { @Html.Raw(p.UuDiem) }
                    else { <span class="text-muted">—</span> }
                </div>
            </div>

            @* 10. Giá tham khảo *@
            <div class="hscn-item">
                <div class="hscn-item-title"><span class="num">10.</span> Giá tham khảo (VNĐ)</div>
                <div class="ps-3 content-body">
                    @if (!string.IsNullOrEmpty(p.GiaBanDuKien)) { @Html.Raw(p.GiaBanDuKien) }
                    else if (p.SellPrice.HasValue)
                    {
                        <span class="fw-bold text-danger fs-5">
                            @string.Format("{0:N0}", p.SellPrice) @p.Currency
                        </span>
                        @if (p.OriginalPrice.HasValue)
                        {
                            <span class="text-muted text-decoration-line-through ms-2">
                                @string.Format("{0:N0}", p.OriginalPrice) @p.Currency
                            </span>
                        }
                    }
                    else { <span class="text-muted">—</span> }
                </div>
            </div>

            @* 11. Bảo hành & Hỗ trợ *@
            <div class="hscn-item">
                <div class="hscn-item-title"><span class="num">11.</span> Chế độ bảo hành &amp; Hỗ trợ kỹ thuật</div>
                <div class="ps-3 content-body">
                    @if (!string.IsNullOrEmpty(p.BaoHanhHoTro)) { @Html.Raw(p.BaoHanhHoTro) }
                    else { <span class="text-muted">—</span> }
                </div>
            </div>

            @* Giải thưởng *@
            @if (!string.IsNullOrEmpty(p.GiaiThuong))
            {
                <div class="hscn-item">
                    <div class="hscn-item-title">Giải thưởng / Chứng nhận</div>
                    <div class="ps-3 content-body">@Html.Raw(p.GiaiThuong)</div>
                </div>
            }
        </div>

        @* ══════════════════════════════════════
           TAB 4 – NHÀ CUNG ỨNG
           ══════════════════════════════════════ *@
        <div class="tab-pane fade" id="tb-nhacungung" role="tabpanel">
            <div class="hscn-section-title"><i class="fa fa-building me-2"></i>Thông tin nhà cung ứng</div>

            @* 12. Tên đơn vị *@
            <div class="hscn-item">
                <div class="hscn-item-title"><span class="num">12.</span> Tên đơn vị sở hữu / cung ứng</div>
                <div class="ps-3">
                    @if (supplier != null)
                    {
                        <strong>
                            @if (!string.IsNullOrEmpty(Model.SupplierUrl))
                            {
                                <a href="@Model.SupplierUrl" class="text-decoration-none">@supplier.FullName</a>
                            }
                            else { @supplier.FullName }
                        </strong>
                    }
                    else if (!string.IsNullOrEmpty(Model.SupplierName))
                    {
                        <strong>
                            @if (!string.IsNullOrEmpty(Model.SupplierUrl))
                            {
                                <a href="@Model.SupplierUrl" class="text-decoration-none">@Model.SupplierName</a>
                            }
                            else { @Model.SupplierName }
                        </strong>
                    }
                    else { <span class="text-muted">—</span> }
                </div>
            </div>

            @* 13. Thông tin liên hệ *@
            <div class="hscn-item">
                <div class="hscn-item-title"><span class="num">13.</span> Thông tin liên hệ</div>
                <table class="hscn-table-info ps-3 ms-3" style="font-size:13.5px;">
                    <tbody>
                        @if (supplier != null)
                        {
                            @if (!string.IsNullOrEmpty(supplier.DiaChi))
                            {
                                <tr><td>Địa chỉ:</td><td>@supplier.DiaChi</td></tr>
                            }
                            @if (!string.IsNullOrEmpty(supplier.NguoiDaiDien))
                            {
                                <tr><td>Người đại diện:</td>
                                    <td>@supplier.NguoiDaiDien @(!string.IsNullOrEmpty(supplier.ChucVu) ? $"– {supplier.ChucVu}" : "")</td></tr>
                            }
                            @if (!string.IsNullOrEmpty(supplier.Phone))
                            {
                                <tr><td>Điện thoại:</td><td>@supplier.Phone</td></tr>
                            }
                            @if (!string.IsNullOrEmpty(supplier.Email))
                            {
                                <tr><td>Email:</td><td><a href="mailto:@supplier.Email">@supplier.Email</a></td></tr>
                            }
                            @if (!string.IsNullOrEmpty(supplier.Website))
                            {
                                <tr><td>Website:</td><td><a href="@supplier.Website" target="_blank">@supplier.Website</a></td></tr>
                            }
                        }
                        else
                        {
                            @if (!string.IsNullOrEmpty(p.DiaChi))
                            {
                                <tr><td>Địa chỉ:</td><td>@p.DiaChi</td></tr>
                            }
                            @if (!string.IsNullOrEmpty(p.Phone))
                            {
                                <tr><td>Điện thoại:</td><td>@p.Phone</td></tr>
                            }
                            @if (!string.IsNullOrEmpty(p.OwnerEmail))
                            {
                                <tr><td>Email:</td><td><a href="mailto:@p.OwnerEmail">@p.OwnerEmail</a></td></tr>
                            }
                            @if (!string.IsNullOrEmpty(p.WebUrl))
                            {
                                <tr><td>Website:</td><td><a href="@p.WebUrl" target="_blank">@p.WebUrl</a></td></tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @if (!string.IsNullOrEmpty(Model.SupplierUrl))
            {
                <div class="ps-3 mt-2">
                    <a href="@Model.SupplierUrl" class="btn btn-outline-primary btn-sm">
                        <i class="fa fa-external-link me-1"></i> Xem hồ sơ nhà cung ứng
                    </a>
                </div>
            }
        </div>

    </div>
</div>
